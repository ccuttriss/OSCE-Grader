# OSCE Grader server configuration
OSCE_SERVER_MODE=1
OSCE_LOG_JSON=1
OSCE_DATA_DIR=/var/lib/osce-grader
OSCE_ADMIN_EMAILS=admin@example.edu
OSCE_AUDIT_RETENTION_USER_DAYS=2557
OSCE_AUDIT_RETENTION_SYSTEM_DAYS=90
